{
  "name": "terminal-live-server",
  "version": "1.4.0",
  "description": "Backend WebSocket + node-pty para terminal en tiempo real",
  "main": "index.js",
  "scripts": {
    "start": "node --stack-size=65536 --env-file-if-exists=.env index.js",
    "dev": "nodemon --exec 'node --stack-size=65536 --env-file-if-exists=.env' index.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-datachannel": "^0.32.1",
    "node-pty": "^1.0.0",
    "openai": "^6.29.0",
    "sharp": "^0.33.5",
    "sql.js": "^1.14.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0"
  }
}

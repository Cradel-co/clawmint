# Configuración del servidor
# Copiar este archivo a .env y completar los valores

# Host y puerto del servidor
HOST=0.0.0.0
PORT=3001

# Bot de Telegram para desarrollo
# El servidor crea bots.json automáticamente en el primer arranque
# si bots.json no existe y BOT_TOKEN está definido.

# Token del bot (obtenido desde @BotFather)
BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNN

# Identificador interno del bot (solo letras, números, _ y -)
BOT_KEY=dev

# Agente por defecto para los chats
BOT_DEFAULT_AGENT=claude

# IDs de usuarios de Telegram autorizados, separados por coma (vacío = sin whitelist)
BOT_WHITELIST=

# IDs de grupos de Telegram autorizados, separados por coma (vacío = sin whitelist)
BOT_GROUP_WHITELIST=

# Rate limit en segundos entre mensajes por usuario
BOT_RATE_LIMIT=30

# Palabra clave para saltear el rate limit
BOT_RATE_LIMIT_KEYWORD=

# Clawmint client — local env config.
# Copiar a `.env.local` (no commiteado) y ajustar.

# URL del server (default: hostname:3001)
# VITE_SERVER_URL=localhost:3001

# ── Feature flags (ver client/src/hooks/useFeatureFlag.js) ───────────────
#
# Todos default false. Flip a 'true' cuando quieras activar. Requiere rebuild
# (Vite embebe env vars en build time).

# Fase A — paleta OC-2 + primitives
VITE_FEATURE_NEW_UI=false

# Fase B — paneles admin-only (por implementar)
VITE_FEATURE_PERMISSIONS_PANEL=false
VITE_FEATURE_HOOKS_PANEL=false
VITE_FEATURE_METRICS_DASHBOARD=false
VITE_FEATURE_USERS_PANEL=false
VITE_FEATURE_WORKSPACES_PANEL=false

# Fase C — features activos sin UI (por implementar)
VITE_FEATURE_TASKS_PANEL=false
VITE_FEATURE_SCHEDULER_PANEL=false
VITE_FEATURE_TYPED_MEMORY_PANEL=false
VITE_FEATURE_SESSION_SHARING_UI=false
VITE_FEATURE_MCP_OAUTH_WIZARD=false

# Fase D — UX productividad (por implementar)
VITE_FEATURE_COMMAND_PALETTE=false
VITE_FEATURE_KEYBINDINGS_PANEL=false
VITE_FEATURE_LOGS_STREAMING=false

# Fase E — config avanzada
VITE_FEATURE_COMPACTION_PANEL=false
VITE_FEATURE_MODEL_TIERS_PANEL=false
VITE_FEATURE_TOOLS_FILTER_PANEL=false
VITE_FEATURE_LSP_PANEL=false
VITE_FEATURE_ORCHESTRATION_PANEL=false

# Extras — Skills panel (Fase C)
VITE_FEATURE_SKILLS_PANEL=false
